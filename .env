# No IP address needed — the app auto-detects your PC from the Expo dev server.

EXPO_OFFLINE=1
EXPO_NO_DEPENDENCY_VALIDATION=1

# Dev seller id until login returns real id
EXPO_PUBLIC_DEV_SELLER_ID=1

# Set to true ONLY when using Android Emulator
EXPO_PUBLIC_API_ANDROID_EMULATOR=false

# Optional manual override (normally leave unset):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
