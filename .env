# Production seller API (VPS nginx → seller-service :8083)
EXPO_PUBLIC_API_BASE_URL=https://flintnthread.online
EXPO_PUBLIC_MEDIA_BASE_URL=https://flintnthread.in

EXPO_OFFLINE=1
EXPO_NO_DEPENDENCY_VALIDATION=1

# Dev seller id until login returns real id
EXPO_PUBLIC_DEV_SELLER_ID=1

# Android Emulator only:
EXPO_PUBLIC_API_ANDROID_EMULATOR=false

# --- Local dev only (uncomment to use PC backend instead of VPS) ---
# EXPO_PUBLIC_API_USE_LOCAL=true
# EXPO_PUBLIC_API_WEB_BASE_URL=http://localhost:8083
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8083
