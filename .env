# Your PC LAN IP — phone/emulator must reach this (same Wi‑Fi). Run: ipconfig
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.29:8080

# Dev seller id until login API returns real id
EXPO_PUBLIC_DEV_SELLER_ID=1

# Set to true ONLY when using Android Emulator (uses 10.0.2.2 instead of LAN IP)
EXPO_PUBLIC_API_ANDROID_EMULATOR=false
