# Your PC LAN IP тАФ run `ipconfig` and use IPv4 (phone must be on same WiтАСFi).
# Current machine IP (update when your network changes):
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.13:8080

# Expo web URL for invoice QR codes (use your PC IP + Metro web port, NOT localhost)
EXPO_PUBLIC_APP_BASE_URL=http://192.168.0.13:8082

# Dev seller id until login returns real id
EXPO_PUBLIC_DEV_SELLER_ID=1

# Set to true ONLY when using Android Emulator (uses 10.0.2.2 instead of LAN IP)
EXPO_PUBLIC_API_ANDROID_EMULATOR=false
