# Production seller API (same domain as user app)
# Production seller API (VPS nginx → seller-service :8083). Either domain works.
EXPO_PUBLIC_API_BASE_URL=https://flintnthread.in
# EXPO_PUBLIC_API_BASE_URL=https://flintnthread.in

# Product images CDN (legacy uploads/products on flintnthread.com)
EXPO_PUBLIC_MEDIA_BASE_URL=https://flintnthread.com
EXPO_NO_DEPENDENCY_VALIDATION=1

EXPO_PUBLIC_DEV_SELLER_ID=1

# Android Emulator only:
EXPO_PUBLIC_API_ANDROID_EMULATOR=false

# --- Local dev only ---
# EXPO_PUBLIC_API_USE_LOCAL=true
# EXPO_PUBLIC_API_WEB_BASE_URL=http://localhost:8083
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8083
