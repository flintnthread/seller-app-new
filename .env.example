# Copy this file to .env and set your PC's IPv4 (run: ipconfig → Wireless LAN IPv4)

# Physical phone / tablet on same Wi‑Fi as your PC:
# Run ipconfig on your PC and paste IPv4 here (same Wi-Fi as phone)
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.13:8080

# Android Emulator only — use host loopback alias (set true OR use URL below):
EXPO_PUBLIC_API_ANDROID_EMULATOR=false
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# Web always uses http://localhost:8080 (no need to change for browser)

# Invoice QR on shipping labels — phone must reach this URL (same Wi‑Fi, NOT localhost)
# Use: http://YOUR_PC_IP:8082  (port = Expo web port shown in terminal)
EXPO_PUBLIC_APP_BASE_URL=http://192.168.0.13:8082

EXPO_PUBLIC_DEV_SELLER_ID=1
